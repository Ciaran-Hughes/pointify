# Pointify — copy to .env and edit. Used by Docker Compose (root) and local backend (backend/.env).

# --- Docker: set these for production (docker-compose) ---
# Absolute path on host for DB + audio. Data will live in $DATA_PATH/data
DATA_PATH=/path/to/pointify
# Absolute path for Whisper model cache (large; survives container rebuilds)
WHISPER_CACHE_PATH=/path/to/pointify/whisper_cache

# --- Ollama ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gpt-oss:20b

# --- Auth: use a long random secret (e.g. openssl rand -hex 32) ---
JWT_SECRET=replace-with-openssl-rand-hex-32

# --- Database: leave empty in Docker to use default data/pointify.db in mounted volume ---
DB_PATH=data/pointify.db

# --- CORS: origins that may call the API (comma-separated). Use your app URL(s). ---
CORS_ORIGINS=http://localhost:5173,https://pointify.example.com

# --- Optional ---
LOG_LEVEL=INFO
MAX_UPLOAD_MB=50
MAX_RECORDING_MINUTES=5
# Set true only for local dev — never expose Swagger in production
ENABLE_DOCS=false

# --- Buffer (optional) ---
# Leave both empty to disable Buffer integration entirely (safe default).
# SECURITY: BUFFER_API_TOKEN must stay server-side only — never put it in
# frontend code, env vars exposed to the browser, or commit it to git.
# Generate your token at: https://publish.buffer.com/settings/api
BUFFER_API_TOKEN=
# Your Buffer organization ID (found in Buffer settings, or leave empty to
# auto-discover on first use — works for single-org accounts).
BUFFER_ORGANIZATION_ID=
